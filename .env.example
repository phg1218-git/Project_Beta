# ─────────────────────────────────────────
# 오늘의귤 Project_Beta 환경변수 템플릿
# 이 파일을 복사해서 .env.local 로 사용하세요
# cp .env.example .env.local
# ─────────────────────────────────────────

# Database (PostgreSQL 권장)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/project_beta"

# NextAuth.js / Auth.js v5
AUTH_SECRET="your-secret-here"           # openssl rand -base64 32

# 로컬 개발: AUTH_URL 설정 (Auth.js v5 권장)
# 프로덕션/Netlify: AUTH_URL 또는 AUTH_TRUST_HOST=true 중 하나 사용
# AUTH_URL 없이 trustHost:true 로 동작 가능 (src/auth.ts 에 이미 설정됨)
AUTH_URL="http://localhost:3000"

# Netlify/Vercel 등 동적 URL 환경에서는 아래 대신 AUTH_URL 고정을 권장
# AUTH_TRUST_HOST=true

# 관리자 이메일 (쉼표 구분, 공백 허용)
ADMIN_EMAILS="admin@example.com,another@example.com"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Naver OAuth
AUTH_NAVER_ID="your-naver-client-id"
AUTH_NAVER_SECRET="your-naver-client-secret"

# Kakao OAuth
AUTH_KAKAO_ID="your-kakao-client-id"
AUTH_KAKAO_SECRET="your-kakao-client-secret"

# 입금 계좌 정보 (주문 생성 시 스냅샷으로 저장)
BANK_ACCOUNT_INFO="국민은행 123-456-789012 (오늘의귤)"

# 입금 대기 만료 시간 (시간 단위, 기본값 24)
DEPOSIT_TIMEOUT_HOURS=24
